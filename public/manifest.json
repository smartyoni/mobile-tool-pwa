{
  "manifest_version": 3,
  "name": "도구모음 (모바일 & 확장프로그램)",
  "version": "1.0.0",
  "description": "다양한 도구를 하나로 모은 생산성 앱",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "index.html"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "permissions": [
    "sidePanel",
    "storage"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
